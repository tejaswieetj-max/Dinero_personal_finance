# Supabase Configuration (Required for API and Frontend)
SUPABASE_URL=https://your-project.supabase.co
# ANON_KEY is safe for frontend use in the browser client
SUPABASE_ANON_KEY=your-anon-key
# SERVICE_ROLE_KEY is for BACKEND USE ONLY. NEVER expose to the browser.
# This key bypasses Row Level Security (RLS).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Vercel Deployment Note:
# Add these keys to your Vercel project at:
# Project Settings > Environment Variables
